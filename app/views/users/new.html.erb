<h1>Signup</h1>

<form action="/users" method="post">
  <p>
    <label for="first_name_box">First Name</label>
    <input type="text" name="first_name" id="first_name_box">
  </p>

  <p>
    <label for="last_name_box">Last Name</label>
    <input type="text" name="last_name" id="last_name_box">
  </p>

  <p>
    <label for="email_box">Email</label>
    <input type="text" name="email" id="email_box">
  </p>

  <p>
    <label for="password_box">Password</label>
    <input type="password" name="password" id="password_box">
  </p>

  <button>Submit</button>
</form>