<h1>New Post</h1>

<%# TODO: only display form when user is logged in %>
<% if @current_user == nil %>
  <p>You must login to post.</p>
<% else %>
  <form action="/posts" method="post">
    <p>
      <label for="body_box">Body</label>
      <input type="text" name="body" id="body_box">
    </p>

    <p>
      <label for="image_box">Image URL</label>
      <input type="text" name="image" id="image_box">
    </p>

    <button>Save</button>
  </form>

  <p>
    <a href="/posts">Cancel</a>
  </p>
<% end %>